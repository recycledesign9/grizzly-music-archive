# ─────────────────────────────────────────────────────────────────────────────
# Grizzly Music Archive — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Public URL of the app (no trailing slash)
BASE_URL=http://localhost:8080

# Port exposed on the host machine
APP_PORT=8080

# Additional hostnames allowed to serve the app.
# Values must be comma-separated and can include ports.
ALLOWED_HOSTS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# Set to true only during local development — NEVER in production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=grizzly_db
DB_USER=grizzly
DB_PASS=grizzly_secret
DB_ROOT_PASS=root_secret_change_me

# ── API Keys (all optional) ───────────────────────────────────────────────────
# Without keys the app works normally; automatic cover/metadata fetch is disabled.

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Discogs — https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=
